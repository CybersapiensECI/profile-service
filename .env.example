# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/profileservice
MONGO_DB=profileservice

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_HOST=
RABBITMQ_PORT=5671
RABBITMQ_USERNAME=
RABBITMQ_PASSWORD=
RABBITMQ_VHOST=/
RABBITMQ_SSL_ENABLED=false

# ── Servicios externos ────────────────────────────────────────────────────────
MATCHING_SERVICE_URL=
MATCHING_SERVICE_PATH=
AUTH_SERVICE_URL=
AUTH_SERVICE_PATH=

# ── Inter-service security ────────────────────────────────────────────────────
# Shared secret injected by Kong on internal service-to-service calls.
# Set this in all microservices and configure Kong to add X-Internal-Key header.
# Leave empty to disable the check in local development.
INTERNAL_API_KEY=

# ── Startup ───────────────────────────────────────────────────────────────────
APP_STARTUP_FAIL_FAST=false
