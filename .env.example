# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/profileservice
MONGO_DB=profileservice

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_HOST=
RABBITMQ_PORT=5671
RABBITMQ_USERNAME=
RABBITMQ_PASSWORD=
RABBITMQ_VHOST=/
RABBITMQ_SSL_ENABLED=false

# ── Servicios externos ────────────────────────────────────────────────────────
# Careful when setting the *_PATH vars from Git Bash / MSYS on Windows: a leading
# slash is rewritten to a Windows path, so `--set-env-vars MATCHING_SERVICE_PATH=/api/v1`
# is silently stored as `F:/Program Files/Git/api/v1` and every call 503s.
# Prefix with MSYS_NO_PATHCONV=1 or set the value from the Azure portal.
MATCHING_SERVICE_URL=
MATCHING_SERVICE_PATH=
AUTH_SERVICE_URL=
AUTH_SERVICE_PATH=

# ── Inter-service security ────────────────────────────────────────────────────
# Shared secret guarding /api/v1/internal/**. Calling services send it as the
# X-Internal-Key header; this service compares it against INTERNAL_API_KEY.
# The gateway does NOT inject this header: each caller sends it itself
# (matching-service does so via InternalFeignConfig).
# Required when NODE_ENV=production, where startup aborts if it is unset and
# every internal call would otherwise be rejected with 403. Ignored in local dev.
# Must be identical here and in every calling service.
INTERNAL_API_KEY=

# ── Startup ───────────────────────────────────────────────────────────────────
# Set to true in production to abort startup if MongoDB or Cloudinary are unreachable.
# Leave false (or unset) in development so the service starts without all dependencies up.
APP_STARTUP_CHECKS_ENABLED=false
